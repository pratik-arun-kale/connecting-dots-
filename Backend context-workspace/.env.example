# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME="AI Context Workspace"
APP_VERSION="0.1.0"
APP_ENV=development          # development | staging | production
DEBUG=true

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,chrome-extension://*

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_context_workspace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Constructed by settings (do not set manually unless overriding)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_context_workspace

# ─────────────────────────────────────────────
# Redis (future-ready — not active yet)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json              # json | console

# ─────────────────────────────────────────────
# Future: Auth (placeholder)
# ─────────────────────────────────────────────
# SECRET_KEY=changeme
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────
# Future: AI Pipelines (placeholder)
# ─────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
