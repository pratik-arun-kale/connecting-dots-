# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME="AI Context Workspace"
APP_VERSION="0.1.0"
APP_ENV=development          # development | staging | production
DEBUG=true

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,chrome-extension://*

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_context_workspace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Constructed by settings (do not set manually unless overriding)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_context_workspace

# ─────────────────────────────────────────────
# Redis (future-ready — not active yet)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json              # json | console

# ─────────────────────────────────────────────
# Future: Auth (placeholder)
# ─────────────────────────────────────────────
# SECRET_KEY=changeme
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────
# Ollama — local LLM for answer generation
# Start server: ollama serve
# Pull model:   ollama pull qwen2.5:3b
# ─────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_API_URL=http://localhost:11434
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=512
OLLAMA_TIMEOUT_SEC=60
OLLAMA_CONTEXT_CHUNKS=5

# ─────────────────────────────────────────────
# Future: Cloud AI (placeholder)
# ─────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
